{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "skipLibCheck": true,

    "paths": {
      "apps/cashio-backend/*": ["./*"],
      "*": ["./*"]
    }
  },
  "include": ["./**/*", "../../libs/shared/**/*"],
  "exclude": ["../../node_modules", "node_modules", "dist"]
}
