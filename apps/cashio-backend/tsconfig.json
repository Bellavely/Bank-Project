  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",

    "ignoreDeprecations": "6.0",
    "baseUrl": ".",

    "paths": {
      "*": ["./*"]
